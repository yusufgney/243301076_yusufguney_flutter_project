rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isActor() {
      return isSignedIn() && callerRole() == 'actor';
    }

    function isAgency() {
      return isSignedIn() && callerRole() == 'agency';
    }

    function applicationDocPath(appId) {
      return /databases/$(database)/documents/applications/$(appId);
    }

    /// Project exists and was created by the given uid.
    function projectOwnedBy(projectId, uid) {
      return exists(/databases/$(database)/documents/casting_projects/$(projectId))
        && get(/databases/$(database)/documents/casting_projects/$(projectId)).data.createdBy == uid;
    }

    // ─── /users/{uid} ─────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // ─── /actors/{uid} ───────────────────────────────────────────────────────
    match /actors/{uid} {
      allow read: if isOwner(uid) || isAgency();
      allow write: if isOwner(uid) && isActor();
    }

    // ─── /agencies/{uid} ─────────────────────────────────────────────────────
    match /agencies/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) && isAgency();
    }

    // ─── /casting_projects/{projectId} ───────────────────────────────────────
    match /casting_projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isAgency()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAgency()
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── /applications/{applicationId}  (id = "{actorId}_{projectId}") ───────
    match /applications/{applicationId} {
      // Single-doc listen on a missing application must still be allowed (OR short-circuits).
      allow read: if isSignedIn() && (
        !exists(applicationDocPath(applicationId))
        || resource.data.actorId == request.auth.uid
        || projectOwnedBy(resource.data.projectId, request.auth.uid)
      );

      allow create: if isActor()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isAgency()
        && projectOwnedBy(resource.data.projectId, request.auth.uid)
        && request.resource.data.actorId == resource.data.actorId
        && request.resource.data.projectId == resource.data.projectId;

      // Agency may remove applications when deleting a listing (client batch delete).
      allow delete: if isAgency()
        && projectOwnedBy(resource.data.projectId, request.auth.uid);
    }

    // ─── /notifications/{notificationId} ─────────────────────────────────────
    // App fields: userId, kind, title, body, projectId?, read, createdAt
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Agency creates outcome notifications for actors on their own project.
      allow create: if isAgency()
        && request.resource.data.userId is string
        && request.resource.data.keys().hasAll(['userId', 'kind', 'title', 'body', 'read', 'createdAt'])
        && (
          !('projectId' in request.resource.data)
          || (
            request.resource.data.projectId is string
            && projectOwnedBy(request.resource.data.projectId, request.auth.uid)
          )
        );

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
    }
  }
}
